ninja_required_version = 1.3
cxx = x86_64-conda-linux-gnu-c++
nvcc = /home/spring/miniforge3/envs/ukan/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/spring/miniforge3/envs/ukan/include -I/home/spring/miniforge3/envs/ukan/targets/x86_64-linux/include -I/home/spring/miniforge3/envs/ukan/targets/x86_64-linux/include/cccl -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/spring/miniforge3/envs/ukan/include -I/home/spring/miniforge3/envs/ukan/targets/x86_64-linux/include -I/home/spring/miniforge3/envs/ukan/targets/x86_64-linux/include/cccl -fPIC -I/home/spring/miniforge3/envs/ukan/lib/python3.10/site-packages/torch/include -I/home/spring/miniforge3/envs/ukan/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/spring/miniforge3/envs/ukan/include -I/home/spring/miniforge3/envs/ukan/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=faster_ops -std=c++17
cuda_cflags = -I/home/spring/miniforge3/envs/ukan/lib/python3.10/site-packages/torch/include -I/home/spring/miniforge3/envs/ukan/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/spring/miniforge3/envs/ukan/include -I/home/spring/miniforge3/envs/ukan/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=faster_ops -gencode=arch=compute_75,code=compute_75 -gencode=arch=compute_75,code=sm_75 -ccbin x86_64-conda-linux-gnu-cc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc -MD -MF $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







